# ArcReel Generator Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# 认证配置 (Authentication)
# ============================================================
# 登录用户名（默认: admin）
AUTH_USERNAME=admin
# 登录密码（留空则首次启动时自动生成并回写到此文件）
AUTH_PASSWORD=
# JWT 签名密钥（留空则自动生成，但重启后 token 失效需重新登录）
AUTH_TOKEN_SECRET=

# ============================================================
# gemini 后端选择 (Backend Selection)
# ============================================================
# 可选值: aistudio (默认) 或 vertex
# Options: aistudio (default) or vertex
GEMINI_BACKEND=aistudio

# 可选：分别为图片/视频指定后端（优先级高于 GEMINI_BACKEND）
# Options: aistudio or vertex (takes precedence over GEMINI_BACKEND)
# GEMINI_IMAGE_BACKEND=aistudio
# GEMINI_VIDEO_BACKEND=vertex

# 可选：分别指定图片/视频模型（下拉/计费范围以 cost_calculator 为准）
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# GEMINI_VIDEO_MODEL=veo-3.1-generate-preview

# 可选：是否生成视频音频（仅当视频后端为 Vertex 时可关闭）
# GEMINI_VIDEO_GENERATE_AUDIO=true

# ============================================================
# AI Studio 配置 (当 GEMINI_BACKEND=aistudio 时使用)
# ============================================================
# 从 https://aistudio.google.com/apikey 获取 API 密钥
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# Claude Agent SDK 配置
# ============================================================
# 可选：通过代理/网关自定义 Claude API Base URL
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# 从 https://console.anthropic.com/ 获取 API 密钥
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 可选：claude agent sdk 自定义模型配置，覆盖默认模型设置
# 下面是 Gemini 示例
# ANTHROPIC_MODEL=gemini-3.1-pro-high[1m]
# ANTHROPIC_DEFAULT_HAIKU_MODEL=gemini-3-flash[1m]
# ANTHROPIC_DEFAULT_OPUS_MODEL=gemini-3.1-pro-high[1m]
# ANTHROPIC_DEFAULT_SONNET_MODEL=gemini-3-flash[1m]
# CLAUDE_CODE_SUBAGENT_MODEL=gemini-3.1-pro-high[1m]

# ============================================================
# Vertex AI 配置 (当 GEMINI_BACKEND=vertex 时使用)
# ============================================================
# 将服务账号 JSON 凭证文件放入 vertex_keys/ 目录即可
# 系统会自动读取凭证并从中提取项目 ID
# 无需设置 VERTEX_API_KEY

# GCS Bucket 名称（用于视频延长功能的输出存储）
# Vertex AI 延长视频时需要 GCS 存储，格式: bucket-name（不含 gs:// 前缀）
VERTEX_GCS_BUCKET=your-gcs-bucket-name

# ============================================================
# 速率限制配置 (Rate Limiting Configuration)
# ============================================================
# 图片生成每分钟请求数限制 (默认: 15)
GEMINI_IMAGE_RPM=15
# 视频生成每分钟请求数限制 (默认: 10)
GEMINI_VIDEO_RPM=10
# 两次请求之间的最小间隔（秒）(默认: 3.1)
GEMINI_REQUEST_GAP=3.1

# ============================================================
# 性能配置 (Performance Configuration)
# ============================================================
# 分镜生成时的最大并发线程数 (默认: 3)
STORYBOARD_MAX_WORKERS=3
# 视频生成时的最大并发线程数 (默认: 2)
VIDEO_MAX_WORKERS=2
